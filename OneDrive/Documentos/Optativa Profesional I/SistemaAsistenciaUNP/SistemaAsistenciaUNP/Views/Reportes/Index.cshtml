@model IEnumerable<SistemaAsistenciaUNP.ViewModels.ReporteAsistenciaViewModel>

@{
    ViewData["Title"] = "Reportes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Reportes</h1>
        <p class="text-muted mb-0">
            Consulta general de asistencias con filtros y exportación.
        </p>
    </div>

    <div>
        <a asp-action="ExportarPdf"
           asp-route-fechaInicio="@ViewBag.FechaInicio"
           asp-route-fechaFin="@ViewBag.FechaFin"
           asp-route-carreraId="@ViewBag.CarreraId"
           asp-route-aula="@ViewBag.Aula"
           asp-route-estado="@ViewBag.Estado"
           class="btn btn-outline-danger">
            Exportar PDF
        </a>

        <a asp-action="ExportarCsv"
           asp-route-fechaInicio="@ViewBag.FechaInicio"
           asp-route-fechaFin="@ViewBag.FechaFin"
           asp-route-carreraId="@ViewBag.CarreraId"
           asp-route-aula="@ViewBag.Aula"
           asp-route-estado="@ViewBag.Estado"
           class="btn btn-outline-success">
            Exportar CSV
        </a>
    </div>
</div>

<div class="row mb-4">

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm border-0"
             style="border-left: 6px solid #2563eb !important;">
            <div class="card-body">
                <h6 class="text-muted mb-2">Carreras registradas</h6>
                <h2 class="fw-bold mb-0">@ViewBag.TotalCarreras</h2>
                <small class="text-muted">
                    Oferta académica activa
                </small>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm border-0"
             style="border-left: 6px solid #16a34a !important;">
            <div class="card-body">
                <h6 class="text-muted mb-2">Estudiantes</h6>
                <h2 class="fw-bold mb-0">@ViewBag.TotalEstudiantes</h2>
                <small class="text-muted">
                    Estudiantes registrados
                </small>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm border-0"
             style="border-left: 6px solid #7c3aed !important;">
            <div class="card-body">
                <h6 class="text-muted mb-2">Docentes</h6>
                <h2 class="fw-bold mb-0">@ViewBag.TotalDocentes</h2>
                <small class="text-muted">
                    Profesores disponibles
                </small>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm border-0"
             style="border-left: 6px solid #f97316 !important;">
            <div class="card-body">
                <h6 class="text-muted mb-2">Asistencias</h6>
                <h2 class="fw-bold mb-0">@ViewBag.TotalAsistencias</h2>
                <small class="text-muted">
                    Registros totales
                </small>
            </div>
        </div>
    </div>

</div>

<div class="card shadow-sm mb-4 border-0">
    <div class="card-header bg-light">
        <strong>Filtros del reporte</strong>
    </div>

    <div class="card-body">

        <form asp-action="Index" method="get" class="row g-3">

            <div class="col-md-2">
                <label class="form-label">Fecha inicio</label>

                <input type="date"
                       name="fechaInicio"
                       value="@ViewBag.FechaInicio"
                       class="form-control" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Fecha fin</label>

                <input type="date"
                       name="fechaFin"
                       value="@ViewBag.FechaFin"
                       class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Carrera</label>

                <select name="carreraId"
                        class="form-select"
                        asp-items="ViewBag.Carreras">

                    <option value="">
                        Todas las carreras
                    </option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Aula</label>

                <select name="aula" class="form-select">

                    <option value="">
                        Todas las aulas
                    </option>

                    @foreach (var item in ViewBag.Aulas)
                    {
                        <option value="@item"
                                selected="@(ViewBag.Aula == item)">
                            @item
                        </option>
                    }

                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Estado</label>

                <select name="estado" class="form-select">

                    <option value="">
                        Todos
                    </option>

                    @foreach (var item in ViewBag.Estados)
                    {
                        <option value="@item"
                                selected="@(ViewBag.Estado == item)">
                            @item
                        </option>
                    }

                </select>
            </div>

            <div class="col-md-1 d-flex align-items-end">
                <button type="submit"
                        class="btn btn-primary w-100">
                    Buscar
                </button>
            </div>

            <div class="col-md-12">
                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar filtros
                </a>
            </div>

        </form>

    </div>
</div>

<div class="row mb-4">

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-0 text-white"
             style="background: linear-gradient(135deg, #15803d, #22c55e);">

            <div class="card-body">
                <h6 class="mb-2">Presentes filtrados</h6>
                <h2 class="fw-bold mb-0">
                    @ViewBag.TotalPresentes
                </h2>

                <small>
                    Alumnos que asistieron
                </small>
            </div>

        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-0 text-white"
             style="background: linear-gradient(135deg, #b91c1c, #ef4444);">

            <div class="card-body">
                <h6 class="mb-2">Ausentes filtrados</h6>
                <h2 class="fw-bold mb-0">
                    @ViewBag.TotalAusentes
                </h2>

                <small>
                    Alumnos ausentes
                </small>
            </div>

        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-0 text-dark"
             style="background: linear-gradient(135deg, #facc15, #fde68a);">

            <div class="card-body">
                <h6 class="mb-2">Justificados filtrados</h6>
                <h2 class="fw-bold mb-0">
                    @ViewBag.TotalJustificados
                </h2>

                <small>
                    Ausencias justificadas
                </small>
            </div>

        </div>
    </div>

</div>

<div class="card shadow-sm border-0">

    <div class="card-header bg-light">
        <strong>Detalle de asistencias</strong>
    </div>

    <div class="card-body table-responsive">

        <table class="table table-striped table-hover align-middle">

            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Estudiante</th>
                    <th>Carrera</th>
                    <th>Asignatura</th>
                    <th>Grupo</th>
                    <th>Docente</th>
                    <th>Aula</th>
                    <th>Estado</th>
                    <th>Observaciones</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.Fecha.ToString("dd/MM/yyyy")
                            </td>

                            <td>@item.Estudiante</td>

                            <td>@item.Carrera</td>

                            <td>@item.Asignatura</td>

                            <td>@item.Grupo</td>

                            <td>@item.Docente</td>

                            <td>@item.Aula</td>

                            <td>

                                @if (item.EstadoAsistencia == "Presente")
                                {
                                    <span class="badge bg-success">
                                        Presente
                                    </span>
                                }
                                else if (item.EstadoAsistencia == "Ausente")
                                {
                                    <span class="badge bg-danger">
                                        Ausente
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        Justificado
                                    </span>
                                }

                            </td>

                            <td>
                                @item.Observaciones
                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9"
                            class="text-center text-muted">

                            No se encontraron registros
                            con los filtros seleccionados.

                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>