@model SistemaAsistenciaUNP.Models.Carrera

@{
    ViewData["Title"] = "Create";
}

<h1>Crear</h1>

<h4>Carrera</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Codigo" class="control-label"></label>
                <input asp-for="Codigo" class="form-control" />
                <span asp-validation-for="Codigo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Descripcion" class="control-label"></label>
                <input asp-for="Descripcion" class="form-control" />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CentroUniversitarioId" class="control-label">
                    Centro Universitario
                </label>

                <select asp-for="CentroUniversitarioId"
                        class="form-select"
                        asp-items="ViewBag.CentroUniversitarioId">

                    <option value="">
                        Seleccione un centro universitario
                    </option>

                </select>

                <span asp-validation-for="CentroUniversitarioId" class="text-danger"></span>
            </div>

            <div class="form-group form-check mb-3">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Estado" />
                    @Html.DisplayNameFor(model => model.Estado)
                </label>
            </div>

            <div class="form-group">
                <input type="submit" value="Crear" class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>

<div class="mt-3">
    <a href="/Carreras">Volver</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}