@model IEnumerable<SistemaAsistenciaUNP.Models.Horario>

@{
    ViewData["Title"] = "Horarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Horarios</h1>

    <a asp-action="Create" class="btn btn-primary">
        Nuevo Horario
    </a>
</div>

<div class="mb-3">
    <a href="/" class="btn btn-outline-secondary">
        ← Inicio
    </a>
</div>

<table class="table table-striped table-hover shadow-sm align-middle">
    <thead>
        <tr>
            <th>Día</th>
            <th>Hora inicio</th>
            <th>Hora fin</th>
            <th>Estado</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DiaSemana</td>
                <td>@item.HoraInicio</td>
                <td>@item.HoraFin</td>
                <td>
                    @if (item.Estado)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
                </td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@item.HorarioId" class="btn btn-sm btn-warning">
                            Editar
                        </a>

                        <a asp-action="Details" asp-route-id="@item.HorarioId" class="btn btn-sm btn-info text-white">
                            Detalles
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.HorarioId" class="btn btn-sm btn-danger">
                            Eliminar
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>