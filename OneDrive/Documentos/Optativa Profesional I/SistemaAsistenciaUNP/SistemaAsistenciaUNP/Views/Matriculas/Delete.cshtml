@model SistemaAsistenciaUNP.Models.Matricula

@{
    ViewData["Title"] = "Eliminar";
}

<h1>Eliminar</h1>

<h3>¿Estás seguro que deseas eliminar este registro?</h3>
<div>
    <h4>Matrícula</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Estudiante</dt>
        <dd class="col-sm-10">@Model.Estudiante?.Nombres</dd>

        <dt class="col-sm-2">Grupo</dt>
        <dd class="col-sm-10">@Model.Grupo?.NombreGrupo</dd>

        <dt class="col-sm-2">Asignatura</dt>
        <dd class="col-sm-10">@Model.Grupo?.Asignatura?.Nombre</dd>

        <dt class="col-sm-2">Docente</dt>
        <dd class="col-sm-10">@Model.Grupo?.Docente?.Nombres</dd>

        <dt class="col-sm-2">Aula</dt>
        <dd class="col-sm-10">@Model.Grupo?.Aula?.Nombre</dd>

        <dt class="col-sm-2">Periodo académico</dt>
        <dd class="col-sm-10">@Model.Grupo?.PeriodoAcademico?.Nombre</dd>

        <dt class="col-sm-2">Horario</dt>
        <dd class="col-sm-10">
            @Model.Grupo?.Horario?.DiaSemana
            @if (Model.Grupo?.Horario != null)
            {
                <span> | @Model.Grupo.Horario.HoraInicio.ToString(@"hh\:mm") - @Model.Grupo.Horario.HoraFin.ToString(@"hh\:mm")</span>
            }
        </dd>

        <dt class="col-sm-2">Fecha de matrícula</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.FechaMatricula)</dd>

        <dt class="col-sm-2">Estado</dt>
        <dd class="col-sm-10">
            @if (Model.Estado)
            {
                <span class="badge bg-success">Activo</span>
            }
            else
            {
                <span class="badge bg-danger">Inactivo</span>
            }
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="MatriculaId" />
        <input type="submit" value="Eliminar" class="btn btn-danger" /> |
        <a asp-action="Index">Volver</a>
    </form>
</div>