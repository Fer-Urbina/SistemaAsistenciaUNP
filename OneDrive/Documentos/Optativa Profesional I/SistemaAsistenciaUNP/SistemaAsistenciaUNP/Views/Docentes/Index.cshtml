@model IEnumerable<SistemaAsistenciaUNP.Models.Docente>

@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Docentes</h1>

    <a asp-action="Create" class="btn btn-primary">
        Nuevo Docente
    </a>
</div>
<div class="mb-3">
    <a href="/" class="btn btn-outline-secondary">
        ← Inicio
    </a>
</div>

<table class="table table-striped table-hover shadow-sm align-middle">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombres)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Apellidos)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Correo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Telefono)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Especialidad)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nombres)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Apellidos)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Correo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Telefono)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Especialidad)
            </td>
            <td>
                    @if (item.Estado)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
            </td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@item.DocenteId" class="btn btn-sm btn-warning">
                            Editar
                        </a>

                        <a asp-action="Details" asp-route-id="@item.DocenteId" class="btn btn-sm btn-info text-white">
                            Detalles
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.DocenteId" class="btn btn-sm btn-danger">
                            Eliminar
                        </a>
                    </div>
                </td>
        </tr>
}
    </tbody>
</table>

<nav>
    <ul class="pagination">

        @if ((int)ViewData["PaginaActual"] > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-pagina="@((int)ViewData["PaginaActual"] - 1)"
                   asp-route-buscar="@ViewData["Buscar"]">
                    Anterior
                </a>
            </li>
        }

        @for (int i = 1; i <= (int)ViewData["TotalPaginas"]; i++)
        {
            <li class="page-item @(i == (int)ViewData["PaginaActual"] ? "active" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-pagina="@i"
                   asp-route-buscar="@ViewData["Buscar"]">
                    @i
                </a>
            </li>
        }

        @if ((int)ViewData["PaginaActual"] < (int)ViewData["TotalPaginas"])
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-pagina="@((int)ViewData["PaginaActual"] + 1)"
                   asp-route-buscar="@ViewData["Buscar"]">
                    Siguiente
                </a>
            </li>
        }

    </ul>
</nav>
