@model SistemaAsistenciaUNP.Models.Grupo

@{
    ViewData["Title"] = "Crear";
}

<h1>Crear</h1>

<h4>Grupo</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="NombreGrupo" class="control-label"></label>
                <input asp-for="NombreGrupo" class="form-control" />
                <span asp-validation-for="NombreGrupo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Turno" class="control-label"></label>
                <input asp-for="Turno" class="form-control" />
                <span asp-validation-for="Turno" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Aula" class="control-label"></label>
                <input asp-for="Aula" class="form-control" />
                <span asp-validation-for="Aula" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PeriodoAcademico" class="control-label"></label>
                <input asp-for="PeriodoAcademico" class="form-control" />
                <span asp-validation-for="PeriodoAcademico" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AsignaturaId" class="control-label">Asignatura</label>
                <select asp-for="AsignaturaId" class ="form-control" asp-items="ViewBag.AsignaturaId"></select>
            </div>
            <div class="form-group">
                <label asp-for="DocenteId" class="control-label">Docente</label>
                <select asp-for="DocenteId" class ="form-control" asp-items="ViewBag.DocenteId"></select>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Estado" /> @Html.DisplayNameFor(model => model.Estado)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Crear" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Volver</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
