@{
    ViewData["Title"] = "Reportes";
}

<h1>Reportes</h1>

<p class="text-muted">
    Resumen general de los registros del sistema.
</p>

<hr />

<div class="row">

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Carreras</h5>
                <h2>@ViewBag.TotalCarreras</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Docentes</h5>
                <h2>@ViewBag.TotalDocentes</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Estudiantes</h5>
                <h2>@ViewBag.TotalEstudiantes</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Asignaturas</h5>
                <h2>@ViewBag.TotalAsignaturas</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Grupos</h5>
                <h2>@ViewBag.TotalGrupos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Matrículas</h5>
                <h2>@ViewBag.TotalMatriculas</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Sesiones</h5>
                <h2>@ViewBag.TotalSesiones</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Asistencias</h5>
                <h2>@ViewBag.TotalAsistencias</h2>
            </div>
        </div>
    </div>

</div>

<hr />

<h3 class="mt-4">Reporte de Asistencias</h3>

<p class="text-muted">
    Resumen de asistencias registradas por estado.
</p>

<div class="row">

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-success">
            <div class="card-body">
                <h5>Presentes</h5>
                <h2>@ViewBag.TotalPresentes</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <h5>Ausentes</h5>
                <h2>@ViewBag.TotalAusentes</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-warning">
            <div class="card-body">
                <h5>Justificados</h5>
                <h2>@ViewBag.TotalJustificados</h2>
            </div>
        </div>
    </div>

</div>

<div class="mt-3">
    <a href="/" class="btn btn-outline-secondary">← Inicio</a>
</div>