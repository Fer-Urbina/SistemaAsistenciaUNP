@model IEnumerable<SistemaAsistenciaUNP.Models.Carrera>

@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Carreras</h1>

    <a asp-action="Create" class="btn btn-primary">
        Nueva Carrera
    </a>
</div>
<div class="mb-3">
    <a href="/" class="btn btn-outline-secondary">
        ← Inicio
    </a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="buscar" value="@ViewData["Buscar"]" class="form-control" placeholder="Buscar carrera..." />
        <button type="submit" class="btn btn-primary">Buscar</button>
        <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
    </div>
</form>

<table class="table table-striped table-hover shadow-sm align-middle">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Codigo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descripcion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Codigo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Descripcion)
            </td>
            <td>
                    @if (item.Estado)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
            </td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@item.CarreraId" class="btn btn-sm btn-warning">
                            Editar
                        </a>

                        <a asp-action="Details" asp-route-id="@item.CarreraId" class="btn btn-sm btn-info text-white">
                            Detalles
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.CarreraId" class="btn btn-sm btn-danger">
                            Eliminar
                        </a>
                    </div>
                </td>
        </tr>
}
    </tbody>
</table>

@{
    int paginaActual = Convert.ToInt32(ViewData["PaginaActual"]);
    int totalPaginas = Convert.ToInt32(ViewData["TotalPaginas"]);
    string buscar = ViewData["Buscar"]?.ToString();
}

@if (totalPaginas > 1)
{
    <nav>
        <ul class="pagination">

            @if (paginaActual > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual - 1)" asp-route-buscar="@buscar">
                        Anterior
                    </a>
                </li>
            }

            @for (int i = 1; i <= totalPaginas; i++)
            {
                <li class="page-item @(i == paginaActual ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-buscar="@buscar">
                        @i
                    </a>
                </li>
            }

            @if (paginaActual < totalPaginas)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual + 1)" asp-route-buscar="@buscar">
                        Siguiente
                    </a>
                </li>
            }

        </ul>
    </nav>
}


