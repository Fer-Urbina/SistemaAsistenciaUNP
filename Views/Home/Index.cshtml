@{
    ViewData["Title"] = "Inicio";
}

<div style="font-family: Arial, sans-serif; padding: 30px;">
    <h1 style="color: #1f2937;">Sistema de Asistencia UNP</h1>

    <p style="font-size: 18px; color: #4b5563;">
        Panel principal para la gestión de carreras, docentes, estudiantes, asignaturas, grupos, matrículas, sesiones de clase y asistencias.
    </p>

    <hr />

    <h2 style="margin-top: 30px;">Módulos del sistema</h2>

    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 20px; max-width: 1000px;">

        <a href="/Carreras" style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; text-decoration: none; color: #111827;">
            <h3>Carreras</h3>
            <p>Administrar carreras académicas.</p>
        </a>

        <a href="/Docentes" style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; text-decoration: none; color: #111827;">
            <h3>Docentes</h3>
            <p>Gestionar información de docentes.</p>
        </a>

        <a href="/Estudiantes" style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; text-decoration: none; color: #111827;">
            <h3>Estudiantes</h3>
            <p>Registrar y consultar estudiantes.</p>
        </a>

        <a href="/Asignaturas" style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; text-decoration: none; color: #111827;">
            <h3>Asignaturas</h3>
            <p>Administrar asignaturas por carrera.</p>
        </a>

        <a href="/Grupoes" style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; text-decoration: none; color: #111827;">
            <h3>Grupos</h3>
            <p>Gestionar grupos de clase.</p>
        </a>

        <a href="/Matriculas" style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; text-decoration: none; color: #111827;">
            <h3>Matrículas</h3>
            <p>Registrar matrículas de estudiantes.</p>
        </a>

        <a href="/SesionClases" style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; text-decoration: none; color: #111827;">
            <h3>Sesiones de Clase</h3>
            <p>Crear sesiones de clase por grupo.</p>
        </a>

        <a href="/Asistencias" style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; text-decoration: none; color: #111827;">
            <h3>Asistencias</h3>
            <p>Registrar asistencia de estudiantes.</p>
        </a>

        <a href="/Reportes" style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; text-decoration: none; color: #111827;">
            <h3>Reportes</h3>
            <p>Visualizar estadísticas generales del sistema.</p>
        </a>

    </div>
</div>